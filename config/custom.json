{
  "model": {
    "adapter_type": "custom",
    "default_model_name": "your-model-name",
    "temperature": 0.7,
    "max_output_tokens": 4096,
    "api_key": "${CUSTOM_API_KEY}",
    "api_base": "https://your-api-endpoint.example.com/v1",
    "timeout_ms": 60000,
    "max_retries": 3,
    "session_mode": "stateless"
  },
  "context": {
    "max_context_tokens": 8192,
    "reserve_for_output": 1024
  },
  "logging": {
    "level": "INFO"
  }
}
