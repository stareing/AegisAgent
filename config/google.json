{
  "model": {
    "adapter_type": "google",
    "default_model_name": "gemini-2.0-flash",
    "temperature": 0.7,
    "max_output_tokens": 8192,
    "api_key": "${GOOGLE_API_KEY}",
    "timeout_ms": 60000,
    "max_retries": 3
  },
  "context": {
    "max_context_tokens": 1000000,
    "reserve_for_output": 8192
  },
  "logging": {
    "level": "INFO"
  }
}
