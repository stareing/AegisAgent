{
  "model": {
    "adapter_type": "openai",
    "default_model_name": "gpt-4o",
    "temperature": 0.7,
    "max_output_tokens": 4096,
    "api_key": "${OPENAI_API_KEY}",
    "api_base": null,
    "timeout_ms": 60000,
    "max_retries": 3
  },
  "context": {
    "max_context_tokens": 128000,
    "reserve_for_output": 4096
  },
  "logging": {
    "level": "INFO"
  }
}
