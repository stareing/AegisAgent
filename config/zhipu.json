{
  "model": {
    "adapter_type": "zhipu",
    "default_model_name": "glm-4",
    "temperature": 0.7,
    "max_output_tokens": 4096,
    "api_key": "${ZHIPU_API_KEY}",
    "api_base": "https://open.bigmodel.cn/api/paas/v4",
    "timeout_ms": 60000,
    "max_retries": 3,
    "session_mode": "stateless"
  },
  "context": {
    "max_context_tokens": 128000,
    "reserve_for_output": 4096
  },
  "logging": {
    "level": "INFO"
  }
}
