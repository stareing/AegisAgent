{
  "graph": {
    "name": "research_and_summarize",
    "description": "Research a topic, then summarize findings",

    "state": {
      "task": {"type": "str", "default": ""},
      "research": {"type": "str", "default": ""},
      "summary": {"type": "str", "default": ""},
      "steps": {"type": "list", "reducer": "add", "default": []}
    },

    "nodes": {
      "researcher": {
        "type": "agent",
        "task_key": "task",
        "output_key": "research",
        "system_prompt": "You are a research assistant. Investigate the topic thoroughly and return detailed findings."
      },
      "summarizer": {
        "type": "agent",
        "task_key": "research",
        "output_key": "summary",
        "system_prompt": "You are a summarization expert. Condense the research into a clear, concise summary."
      }
    },

    "edges": [
      {"from": "__start__", "to": "researcher"},
      {"from": "researcher", "to": "summarizer"},
      {"from": "summarizer", "to": "__end__"}
    ],

    "entry_state": {
      "task": "Explain the key differences between Python asyncio and threading"
    }
  },

  "model": {
    "adapter_type": "deepseek",
    "default_model_name": "deepseek-chat",
    "temperature": 0.7,
    "max_output_tokens": 4096,
    "api_key": "${DEEPSEEK_API_KEY}",
    "api_base": "https://api.deepseek.com"
  },
  "context": {
    "max_context_tokens": 65536,
    "reserve_for_output": 4096
  },
  "logging": {
    "level": "INFO"
  }
}
