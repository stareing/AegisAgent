{
  "model": {
    "adapter_type": "anthropic",
    "default_model_name": "claude-sonnet-4-20250514",
    "temperature": 1.0,
    "max_output_tokens": 8192,
    "api_key": "${ANTHROPIC_API_KEY}",
    "api_base": null,
    "timeout_ms": 60000,
    "max_retries": 3,
    "session_mode": "stateless"
  },
  "context": {
    "max_context_tokens": 200000,
    "reserve_for_output": 8192
  },
  "logging": {
    "level": "INFO"
  }
}
