{
  "model": {
    "adapter_type": "deepseek",
    "default_model_name": "deepseek-chat",
    "temperature": 0.7,
    "max_output_tokens": 4096,
    "api_key": "${DEEPSEEK_API_KEY}",
    "api_base": "https://api.deepseek.com",
    "timeout_ms": 60000,
    "max_retries": 3,
    "session_mode": "stateless"
  },
  "context": {
    "max_context_tokens": 65536,
    "reserve_for_output": 4096
  },
  "logging": {
    "level": "INFO"
  }
}
